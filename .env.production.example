# ============================================================
# AFOS System — Production Environment Variables Template
# Copy to .env.production (or inject via platform secrets)
# DO NOT commit the actual .env.production file
# ============================================================

# ── APPLICATION (REQUIRED) ────────────────────────────────────────────────
NODE_ENV="production"

# Canonical public URL of the application (used for CSRF origin validation)
APP_URL="https://afos.yourdomain.com"

# ── DATABASE (REQUIRED) ───────────────────────────────────────────────────
# PostgreSQL connection string.
# For serverless/edge deployments use a connection pooler (e.g. PgBouncer, Neon).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/afos_production?schema=public"

# ── SESSION (OPTIONAL) ────────────────────────────────────────────────────
# Session cookie lifetime in seconds. Default: 28800 (8 hours).
# SESSION_MAX_AGE=28800

# ── REMINDERS (REQUIRED if email reminders are used) ─────────────────────
# Shared secret for authorising internal calls to /api/reminders/send.
# Generate with: openssl rand -hex 32
REMINDERS_SECRET="generate-a-strong-random-secret-here"

# ── SMTP / EMAIL (REQUIRED if reminders are enabled) ─────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="AFOS System <noreply@example.com>"

# Recipient for reminder emails (defaults to SMTP_USER if not set)
REMINDERS_TO="accountant@example.com"

# ── RATE LIMITING (OPTIONAL — defaults shown) ─────────────────────────────
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_LOGIN=10
# RATE_LIMIT_MAX_REGISTER=5
# RATE_LIMIT_MAX_REMINDERS=5

# ── SEED / ADMIN BOOTSTRAP (FIRST RUN ONLY) ──────────────────────────────
# Used by scripts/seed-test-admin.mjs during initial setup.
# REMOVE these variables from production after the first admin account exists.
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="change-me-immediately-after-first-login"
