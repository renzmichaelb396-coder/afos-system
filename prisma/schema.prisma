generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}


enum Role {
  ACCOUNTANT
  ADMIN
  MANAGER
  STAFF
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id         String   @id @default(cuid())
  name       String
  email      String?  @unique
  monthlyFee Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // v2.2 soft delete
  deletedAt  DateTime?

  payments        Payment[]
  monthlyStatuses ClientStatusByMonth[]
  projects        Project[]
}

model Payment {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  billingPeriodId String
  billingPeriod   BillingPeriod @relation(fields: [billingPeriodId], references: [id])

  amount Int
  paidAt DateTime @default(now())

  // v3.12 soft-delete
  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  idempotencyKey String? @unique
  @@index([clientId, amount, paidAt])
  @@index([clientId, deletedAt])
  @@index([billingPeriodId])
}

model BillingPeriod {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  createdAt DateTime @default(now())

  // v3.12 locking
  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedById String?

  clientStatuses ClientStatusByMonth[]

  payments Payment[]

  @@unique([year, month])
}

model ClientStatusByMonth {
  id              String @id @default(cuid())
  clientId        String
  billingPeriodId String
  status          String @default("UNPAID")

  client        Client        @relation(fields: [clientId], references: [id])
  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id])

  @@unique([clientId, billingPeriodId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  entityType String
  entityId   String
  action     String
  meta       Json?
  createdAt  DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ACCOUNTANT)
  createdAt DateTime @default(now())

  // Account lockout & lifecycle
  isActive         Boolean   @default(true)
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
}

/// Key-value store for system-wide configuration.
/// Keys are stable strings; values are JSON-encoded strings.
model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}


model Project {
  id             String        @id @default(cuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  projectName    String
  contractAmount Int
  startDate      DateTime?
  endDate        DateTime?
  status         ProjectStatus @default(PLANNING)
  location       String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([clientId])
}
