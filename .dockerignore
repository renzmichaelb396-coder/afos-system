# Source control
.git
.gitignore

# Dependencies (rebuilt inside Docker)
node_modules

# Next.js build output (rebuilt inside Docker)
.next

# Local env files — NEVER bake secrets into the image
.env
.env.*
!.env*.example

# Dev/test artifacts
coverage
backups
*.bak.*
*.log
dev.log
/tmp

# CI/CD
.github

# Docs and tooling (not needed at runtime)
docs
tools
scripts
tests
